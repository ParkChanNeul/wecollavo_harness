{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeCollavo Service Catalog",
  "type": "object",
  "required": ["version", "services"],
  "properties": {
    "version": { "type": "string" },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "service_id",
          "public_name",
          "public_starting_price",
          "public_starting_price_krw",
          "scope_standard",
          "included",
          "options",
          "guardrail"
        ],
        "properties": {
          "service_id": { "type": "string", "minLength": 1 },
          "public_name": { "type": "string", "minLength": 1 },
          "public_starting_price": { "type": "string", "minLength": 1 },
          "public_starting_price_krw": { "type": "integer", "minimum": 0 },
          "scope_standard": { "type": "string", "minLength": 1 },
          "included": { "type": "array", "items": { "type": "string" } },
          "options": { "type": "array", "items": { "type": "string" } },
          "guardrail": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
