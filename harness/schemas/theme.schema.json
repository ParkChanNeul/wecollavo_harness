{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeCollavo Proposal Theme",
  "type": "object",
  "required": ["brand_name", "colors", "typography"],
  "properties": {
    "brand_name": { "type": "string" },
    "colors": {
      "type": "object",
      "required": ["background", "text", "accent", "muted"],
      "properties": {
        "background": { "type": "string" },
        "text": { "type": "string" },
        "accent": { "type": "string" },
        "muted": { "type": "string" }
      }
    },
    "typography": {
      "type": "object",
      "required": ["font_family"],
      "properties": {
        "font_family": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
