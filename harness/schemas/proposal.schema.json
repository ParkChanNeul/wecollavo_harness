{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeCollavo Proposal Data",
  "type": "object",
  "required": [
    "client_id",
    "proposal_title",
    "track",
    "pricing_status",
    "human_review_status",
    "confirmed_facts",
    "assumptions",
    "pricing_items",
    "commercial_terms",
    "sections"
  ],
  "properties": {
    "client_id": { "type": "string" },
    "proposal_title": { "type": "string" },
    "track": { "type": "string" },
    "pricing_status": {
      "type": "string",
      "enum": ["field_diagnostic_proposal", "first_written_proposal", "final_estimate"]
    },
    "human_review_status": {
      "type": "string",
      "enum": ["pending", "approved", "blocked"]
    },
    "confirmed_facts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "commercial_terms": {
      "type": "object",
      "required": [
        "payment_terms",
        "revision_policy",
        "additional_terms",
        "final_estimate_notice",
        "delivery_condition",
        "file_retention_days",
        "minor_fix_days"
      ],
      "properties": {
        "payment_terms": { "type": "string", "minLength": 1 },
        "revision_policy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["asset", "feedback_rounds", "description"],
            "properties": {
              "asset": { "type": "string", "minLength": 1 },
              "feedback_rounds": { "type": "integer", "minimum": 0 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "additional_terms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "final_estimate_notice": { "type": "string", "minLength": 1 },
        "delivery_condition": { "type": "string", "minLength": 1 },
        "file_retention_days": { "type": "integer", "minimum": 0 },
        "minor_fix_days": { "type": "integer", "minimum": 0 }
      }
    },
    "pricing_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "service_id",
          "service_name",
          "pricing_model",
          "tier",
          "public_starting_price",
          "minimum_project_fee",
          "internal_price_band",
          "included_rounds",
          "extra_cost_triggers"
        ],
        "properties": {
          "service_id": { "type": "string", "minLength": 1 },
          "service_name": { "type": "string", "minLength": 1 },
          "pricing_model": {
            "type": "string",
            "enum": ["starting_price", "package", "page_based", "project_based", "retainer", "cost_plus"]
          },
          "tier": {
            "type": "string",
            "enum": ["basic", "standard", "premium", "custom"]
          },
          "public_starting_price": { "type": "string", "minLength": 1 },
          "minimum_project_fee": { "type": "string", "minLength": 1 },
          "internal_price_band": {
            "type": "object",
            "required": ["min", "standard", "premium", "basis"],
            "properties": {
              "min": { "type": "string", "minLength": 1 },
              "standard": { "type": "string", "minLength": 1 },
              "premium": { "type": "string", "minLength": 1 },
              "basis": { "type": "string", "minLength": 1 }
            }
          },
          "included_rounds": {
            "type": "object",
            "required": ["planning", "copy", "design", "development", "final_check"],
            "properties": {
              "planning": { "type": "integer", "minimum": 0 },
              "copy": { "type": "integer", "minimum": 0 },
              "design": { "type": "integer", "minimum": 0 },
              "development": { "type": "integer", "minimum": 0 },
              "final_check": { "type": "integer", "minimum": 0 }
            }
          },
          "extra_cost_triggers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "required": ["id", "title", "body"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "array", "items": { "type": "string" } },
          "items": { "type": "array", "items": { "type": "string" } },
          "table": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "additionalProperties": true
}
