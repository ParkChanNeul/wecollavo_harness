{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeCollavo Proposal Data",
  "type": "object",
  "required": [
    "client_id",
    "proposal_title",
    "track",
    "pricing_status",
    "human_review_status",
    "confirmed_facts",
    "assumptions",
    "commercial_terms",
    "sections"
  ],
  "properties": {
    "client_id": { "type": "string" },
    "proposal_title": { "type": "string" },
    "track": { "type": "string" },
    "pricing_status": {
      "type": "string",
      "enum": ["field_diagnostic_proposal", "first_written_proposal", "final_estimate"]
    },
    "human_review_status": {
      "type": "string",
      "enum": ["pending", "approved", "blocked"]
    },
    "confirmed_facts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "commercial_terms": {
      "type": "object",
      "required": [
        "payment_terms",
        "revision_policy",
        "additional_terms",
        "final_estimate_notice"
      ],
      "properties": {
        "payment_terms": { "type": "string", "minLength": 1 },
        "revision_policy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["asset", "feedback_rounds", "description"],
            "properties": {
              "asset": { "type": "string", "minLength": 1 },
              "feedback_rounds": { "type": "integer", "minimum": 0 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "additional_terms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "final_estimate_notice": { "type": "string", "minLength": 1 }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "required": ["id", "title", "body"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "array", "items": { "type": "string" } },
          "items": { "type": "array", "items": { "type": "string" } },
          "table": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "additionalProperties": true
}
