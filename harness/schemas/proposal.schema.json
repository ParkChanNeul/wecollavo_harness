{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WeCollavo Proposal Data",
  "type": "object",
  "required": [
    "client_id",
    "proposal_title",
    "track",
    "pricing_status",
    "human_review_status",
    "request_lock_status",
    "confirmed_facts",
    "assumptions",
    "strategy_context",
    "hard_locks",
    "assumption_locks",
    "remaining_unknowns",
    "department_handoff",
    "pricing_items",
    "commercial_terms",
    "sections"
  ],
  "properties": {
    "client_id": { "type": "string" },
    "proposal_title": { "type": "string" },
    "track": { "type": "string" },
    "pricing_status": {
      "type": "string",
      "enum": ["field_diagnostic_proposal", "first_written_proposal", "final_estimate"]
    },
    "human_review_status": {
      "type": "string",
      "enum": ["pending", "approved", "blocked"]
    },
    "request_lock_status": {
      "type": "string",
      "enum": ["open", "partial", "locked"],
      "description": "Request Lock state. Validation accepts open, partial, and locked, but customer delivery safety requires locked."
    },
    "confirmed_facts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "strategy_context": {
      "type": "object",
      "required": [
        "desired_change",
        "smallest_viable_market",
        "trust_indicators"
      ],
      "properties": {
        "desired_change": {
          "type": "object",
          "required": ["raw_request", "current_state", "target_state", "tension", "change_type", "required_asset"],
          "properties": {
            "raw_request": { "type": "string" },
            "current_state": { "type": "string" },
            "target_state": { "type": "string" },
            "tension": { "type": "string" },
            "change_type": { "type": "string" },
            "required_asset": { "type": "string" }
          }
        },
        "smallest_viable_market": {
          "type": "object",
          "required": ["svm_status", "first_audience", "worldview", "exclusion", "viability_signal", "founder_market_fit"],
          "properties": {
            "svm_status": {
              "type": "string",
              "enum": ["undefined", "broad", "narrow_but_not_viable", "viable", "locked"]
            },
            "first_audience": { "type": "string" },
            "worldview": { "type": "string" },
            "exclusion": { "type": "string" },
            "viability_signal": { "type": "string" },
            "founder_market_fit": { "type": "string" }
          }
        },
        "trust_indicators": {
          "type": "object",
          "required": ["warm_pistachio_signal", "strategic_no_signal", "judgment_benchmark", "status_shift_narrative", "dip_response"],
          "properties": {
            "warm_pistachio_signal": { "type": "string" },
            "strategic_no_signal": { "type": "string" },
            "judgment_benchmark": { "type": "string" },
            "status_shift_narrative": { "type": "string" },
            "dip_response": { "type": "string" }
          }
        }
      }
    },
    "hard_locks": {
      "type": "array",
      "description": "Customer-confirmed facts locked before proposal creation.",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumption_locks": {
      "type": "array",
      "description": "Customer-approved WeCollavo assumptions locked before proposal creation.",
      "items": { "type": "string", "minLength": 1 }
    },
    "remaining_unknowns": {
      "type": "object",
      "description": "v1 uses string arrays. This may later expand to object arrays with owner, deadline, source, and resolution status.",
      "required": [
        "harmless_unknown",
        "proposal_blocking_unknown",
        "price_affecting_unknown",
        "risk_unknown"
      ],
      "properties": {
        "harmless_unknown": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proposal_blocking_unknown": {
          "type": "array",
          "items": { "type": "string" }
        },
        "price_affecting_unknown": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_unknown": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "department_handoff": {
      "type": "object",
      "description": "Structured department object is the preferred v1.1 format. Legacy string arrays are allowed only for transition compatibility.",
      "required": [
        "marketing_planning",
        "commercial_pricing",
        "design",
        "web_development",
        "content",
        "risk_guard",
        "proposal_writer"
      ],
      "properties": {
        "marketing_planning": {
          "$ref": "#/$defs/departmentBrief"
        },
        "commercial_pricing": {
          "$ref": "#/$defs/departmentBrief"
        },
        "design": {
          "$ref": "#/$defs/departmentBrief"
        },
        "web_development": {
          "$ref": "#/$defs/departmentBrief"
        },
        "content": {
          "$ref": "#/$defs/departmentBrief"
        },
        "risk_guard": {
          "$ref": "#/$defs/departmentBrief"
        },
        "proposal_writer": {
          "$ref": "#/$defs/departmentBrief"
        }
      }
    },
    "commercial_terms": {
      "type": "object",
      "required": [
        "payment_terms",
        "revision_policy",
        "additional_terms",
        "final_estimate_notice",
        "delivery_condition",
        "file_retention_days",
        "minor_fix_days"
      ],
      "properties": {
        "payment_terms": { "type": "string", "minLength": 1 },
        "revision_policy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["asset", "feedback_rounds", "description"],
            "properties": {
              "asset": { "type": "string", "minLength": 1 },
              "feedback_rounds": { "type": "integer", "minimum": 0 },
              "description": { "type": "string", "minLength": 1 }
            }
          }
        },
        "additional_terms": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "final_estimate_notice": { "type": "string", "minLength": 1 },
        "delivery_condition": { "type": "string", "minLength": 1 },
        "file_retention_days": { "type": "integer", "minimum": 0 },
        "minor_fix_days": { "type": "integer", "minimum": 0 }
      }
    },
    "pricing_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "service_id",
          "service_name",
          "pricing_model",
          "tier",
          "public_starting_price",
          "minimum_project_fee",
          "internal_price_band",
          "included_rounds",
          "extra_cost_triggers"
        ],
        "properties": {
          "service_id": { "type": "string", "minLength": 1 },
          "service_name": { "type": "string", "minLength": 1 },
          "pricing_model": {
            "type": "string",
            "enum": ["starting_price", "package", "page_based", "project_based", "retainer", "cost_plus"]
          },
          "tier": {
            "type": "string",
            "enum": ["basic", "standard", "premium", "custom"]
          },
          "public_starting_price": { "type": "string", "minLength": 1 },
          "minimum_project_fee": { "type": "string", "minLength": 1 },
          "internal_price_band": {
            "type": "object",
            "required": ["min", "standard", "premium", "basis"],
            "properties": {
              "min": { "type": "string", "minLength": 1 },
              "standard": { "type": "string", "minLength": 1 },
              "premium": { "type": "string", "minLength": 1 },
              "basis": { "type": "string", "minLength": 1 }
            }
          },
          "included_rounds": {
            "type": "object",
            "required": ["planning", "copy", "design", "development", "final_check"],
            "properties": {
              "planning": { "type": "integer", "minimum": 0 },
              "copy": { "type": "integer", "minimum": 0 },
              "design": { "type": "integer", "minimum": 0 },
              "development": { "type": "integer", "minimum": 0 },
              "final_check": { "type": "integer", "minimum": 0 }
            }
          },
          "extra_cost_triggers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "required": ["id", "title", "body"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "array", "items": { "type": "string" } },
          "items": { "type": "array", "items": { "type": "string" } },
          "table": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "$defs": {
    "departmentBrief": {
      "oneOf": [
        {
          "type": "array",
          "description": "Legacy transition format.",
          "items": { "type": "string" }
        },
        {
          "type": "object",
          "description": "Preferred structured Department Analysis Brief format.",
          "required": [
            "diagnosis",
            "recommendation",
            "scope_impact",
            "price_impact",
            "risks",
            "missing_inputs",
            "proposal_points",
            "client_safe_phrase",
            "trust_indicator"
          ],
          "properties": {
            "diagnosis": { "type": "array", "items": { "type": "string" } },
            "recommendation": { "type": "array", "items": { "type": "string" } },
            "scope_impact": { "type": "array", "items": { "type": "string" } },
            "price_impact": { "type": "array", "items": { "type": "string" } },
            "risks": { "type": "array", "items": { "type": "string" } },
            "missing_inputs": { "type": "array", "items": { "type": "string" } },
            "proposal_points": { "type": "array", "items": { "type": "string" } },
            "client_safe_phrase": { "type": "array", "items": { "type": "string" } },
            "trust_indicator": { "type": "array", "items": { "type": "string" } }
          }
        }
      ]
    }
  },
  "additionalProperties": true
}
